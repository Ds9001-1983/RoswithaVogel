---
import { getImage } from "astro:assets";
import galleryData from "../data/gallery.json";

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.jpg",
  { eager: true }
);
const lookup: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(galleryModules)) {
  lookup[path.split("/").pop()!] = mod.default;
}

const items = await Promise.all(
  galleryData
    .map((g) => ({ ...g, src: lookup[g.file] }))
    .filter((g) => !!g.src)
    .map(async (g) => {
      const optimized = await getImage({
        src: g.src!,
        widths: [480, 720, 1080, 1440],
        formats: ["avif", "webp", "jpg"],
      });
      const full = await getImage({
        src: g.src!,
        format: "webp",
        quality: 88,
      });
      return {
        ...g,
        thumbSrc: optimized.src,
        thumbSrcset: optimized.srcSet.attribute,
        fullSrc: full.src,
        width: g.src!.width,
        height: g.src!.height,
        orientation:
          g.src!.width >= g.src!.height ? "landscape" : "portrait",
      } as const;
    })
);

const landscape = items.filter((i) => i.orientation === "landscape");
const portrait = items.filter((i) => i.orientation === "portrait");

const priceLabel = (p: number | null) =>
  p == null ? "Preis auf Anfrage" : `${p} €`;

type Item = (typeof items)[number];
const sliderSections: Array<{
  id: string;
  orientation: "landscape" | "portrait";
  title: string;
  ariaLabel: string;
  items: Item[];
}> = [
  {
    id: "gallery-landscape",
    orientation: "landscape",
    title: "Querformat",
    ariaLabel: "Werke im Querformat",
    items: landscape,
  },
  {
    id: "gallery-portrait",
    orientation: "portrait",
    title: "Hochformat",
    ariaLabel: "Werke im Hochformat",
    items: portrait,
  },
];
---

<section id="galerie" class="px-6 py-20 sm:py-28 lg:py-40">
  <div class="max-w-[1600px] mx-auto">
    <div class="text-center mb-14 sm:mb-20 reveal max-w-[760px] mx-auto px-4">
      <p class="font-display italic text-[var(--color-accent)] text-base sm:text-lg mb-2 sm:mb-3" style="letter-spacing:0.02em;">Die Künstlerin</p>
      <h2 class="font-display font-medium text-[clamp(34px,5.2vw,72px)] leading-[1.05]" style="letter-spacing:-0.015em;">
        Acryl. Großformatig.<br class="sm:hidden"/> Aus dem Pfälzer Wald.
      </h2>
      <p class="mt-4 sm:mt-5 text-[var(--color-ink-soft)] max-w-[58ch] mx-auto leading-relaxed text-[15px] sm:text-base">
        Eine wachsende Sammlung großformatiger Acryl-Werke — sortiert nach
        Format. Bei Interesse an einem Bild bitte über Facebook oder per
        Mail Kontakt aufnehmen; alle Preise verstehen sich inklusive Versand
        innerhalb Deutschlands.
      </p>
    </div>

    {sliderSections.map((section) => (
      <div class="format-section reveal" data-orientation={section.orientation}>
        <header class="format-header">
          <h3 class="font-display">{section.title}</h3>
          <span class="format-count">{section.items.length} Werke</span>
        </header>

        <div class="gallery-slider" data-orientation={section.orientation}>
          <div
            class="slider-track"
            id={section.id}
            tabindex="0"
            role="region"
            aria-label={section.ariaLabel}
          >
            <ul class="slider-list">
              {section.items.map((item, i) => (
                <li class="slide" data-idx={i} data-active={i === 0 ? "true" : "false"}>
                  <a
                    class="slide-link"
                    href={item.fullSrc}
                    data-pswp-width={item.width}
                    data-pswp-height={item.height}
                    data-title={item.title}
                    data-dims={item.dims}
                    data-price={priceLabel(item.price)}
                    target="_blank"
                    rel="noopener"
                    aria-label={`${item.title} — ${item.dims} — Großansicht öffnen`}
                  >
                    <img
                      src={item.thumbSrc}
                      srcset={item.thumbSrcset}
                      sizes={
                        section.orientation === "landscape"
                          ? "(min-width: 1024px) 620px, (min-width: 640px) 60vw, 88vw"
                          : "(min-width: 1024px) 420px, (min-width: 640px) 40vw, 64vw"
                      }
                      alt={`${item.title} — ${item.dims}`}
                      loading={i < 2 ? "eager" : "lazy"}
                      decoding="async"
                      width={item.width}
                      height={item.height}
                      style={`aspect-ratio: ${item.width} / ${item.height};`}
                    />
                  </a>
                  <p class="slide-meta">
                    <strong>{item.title}</strong>
                    <span>{item.dims} · {priceLabel(item.price)}</span>
                  </p>
                </li>
              ))}
            </ul>
          </div>

          <div class="slider-controls">
            <button class="slider-btn slider-prev" type="button" aria-label="Voriges Werk">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <span class="slider-counter" aria-live="polite">1 / {section.items.length}</span>
            <button class="slider-btn slider-next" type="button" aria-label="Nächstes Werk">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // Slider-Steuerung pro Format-Sektion
  const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const sliders = document.querySelectorAll<HTMLElement>(".gallery-slider");

  sliders.forEach((slider) => {
    const track = slider.querySelector<HTMLElement>(".slider-track")!;
    const slides = Array.from(slider.querySelectorAll<HTMLElement>(".slide"));
    const prev = slider.querySelector<HTMLButtonElement>(".slider-prev")!;
    const next = slider.querySelector<HTMLButtonElement>(".slider-next")!;
    const counter = slider.querySelector<HTMLElement>(".slider-counter")!;
    let activeIdx = 0;

    const setActive = (idx: number) => {
      activeIdx = idx;
      slides.forEach((s, i) =>
        s.setAttribute("data-active", i === idx ? "true" : "false")
      );
      counter.textContent = `${idx + 1} / ${slides.length}`;
      prev.toggleAttribute("disabled", idx === 0);
      next.toggleAttribute("disabled", idx === slides.length - 1);
    };

    // Active-Slide-Tracking: jener Slide, dessen Mittelpunkt der Track-Mitte am nächsten ist.
    // Deterministisch — keine Race-Conditions mit IO-Thresholds.
    let rafId = 0;
    const detectActive = () => {
      const trackCenter = track.scrollLeft + track.clientWidth / 2;
      let bestIdx = 0;
      let bestDist = Infinity;
      slides.forEach((s, i) => {
        const center = s.offsetLeft + s.offsetWidth / 2;
        const dist = Math.abs(center - trackCenter);
        if (dist < bestDist) {
          bestDist = dist;
          bestIdx = i;
        }
      });
      if (bestIdx !== activeIdx) setActive(bestIdx);
    };
    const onScroll = () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(detectActive);
    };
    track.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });

    const scrollToIdx = (idx: number) => {
      const target = slides[idx];
      if (!target) return;
      const trackRect = track.getBoundingClientRect();
      const targetRect = target.getBoundingClientRect();
      const offset =
        targetRect.left -
        trackRect.left +
        track.scrollLeft -
        (trackRect.width - targetRect.width) / 2;
      track.scrollTo({
        left: offset,
        behavior: reducedMotion ? "auto" : "smooth",
      });
    };

    prev.addEventListener("click", () =>
      scrollToIdx(Math.max(0, activeIdx - 1))
    );
    next.addEventListener("click", () =>
      scrollToIdx(Math.min(slides.length - 1, activeIdx + 1))
    );

    track.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        scrollToIdx(Math.max(0, activeIdx - 1));
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        scrollToIdx(Math.min(slides.length - 1, activeIdx + 1));
      } else if (e.key === "Home") {
        e.preventDefault();
        scrollToIdx(0);
      } else if (e.key === "End") {
        e.preventDefault();
        scrollToIdx(slides.length - 1);
      }
    });

    // Initial: vom Markup ist Slide 0 aktiv. Nach dem Mount einmal nachjustieren,
    // falls der Browser irgendwo anders gestartet ist (z.B. nach reload).
    requestAnimationFrame(detectActive);
  });

  // PhotoSwipe-Lightbox — getrennt pro Format-Sektion
  ["#gallery-landscape", "#gallery-portrait"].forEach((sel) => {
    if (!document.querySelector(sel)) return;
    import("photoswipe/lightbox").then(({ default: PhotoSwipeLightbox }) => {
      const lightbox = new PhotoSwipeLightbox({
        gallery: sel,
        children: "a.slide-link",
        pswpModule: () => import("photoswipe"),
        bgOpacity: 0.95,
        showHideAnimationType: "fade",
      });
      lightbox.on("uiRegister", () => {
        lightbox.pswp?.ui?.registerElement({
          name: "custom-caption",
          order: 9,
          isButton: false,
          appendTo: "root",
          html: '<div class="pswp__custom-caption"></div>',
          onInit: (el) => {
            lightbox.pswp?.on("change", () => {
              const slide = lightbox.pswp?.currSlide?.data.element as HTMLAnchorElement | undefined;
              if (!slide) return;
              const title = slide.dataset.title ?? "";
              const dims = slide.dataset.dims ?? "";
              const price = slide.dataset.price ?? "";
              el.innerHTML = `<strong>${title}</strong><br/>${dims} · ${price}`;
            });
          },
        });
      });
      lightbox.init();
    });
  });

  // Minimaler PhotoSwipe-Caption-Style (eigener Stil, klein)
  const captionCss = `
    .pswp__custom-caption {
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      color: #f6f2ea;
      font-family: 'EB Garamond', Georgia, serif;
      font-size: 16px;
      letter-spacing: 0.02em;
      background: rgba(10,8,7,0.55);
      backdrop-filter: blur(8px);
      padding: 10px 18px;
      border-radius: 999px;
      max-width: min(90vw, 600px);
      text-align: center;
    }
    .pswp__custom-caption strong { font-size: 19px; font-weight: 600; }
  `;
  const style = document.createElement("style");
  style.textContent = captionCss;
  document.head.appendChild(style);
</script>
