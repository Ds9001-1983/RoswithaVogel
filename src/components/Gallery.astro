---
import { getImage } from "astro:assets";
import galleryData from "../data/gallery.json";

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.jpg",
  { eager: true }
);
const lookup: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(galleryModules)) {
  lookup[path.split("/").pop()!] = mod.default;
}

// Span je Werk anhand des Seitenverhaeltnisses bestimmen — gibt den Bento-Mix
const computeSpan = (w: number, h: number, idx: number): string => {
  const r = w / h;
  // Jeder 7. wird zur "Hero"-Tile (2x2)
  if (idx % 7 === 0) return "md:col-span-2 md:row-span-2";
  if (r >= 1.6) return "md:col-span-2 md:row-span-1"; // breites Querformat
  if (r <= 0.65) return "md:col-span-1 md:row-span-2"; // klassisches Hochformat
  return "md:col-span-1 md:row-span-1"; // 1x1
};

const items = await Promise.all(
  galleryData
    .map((g) => ({ ...g, src: lookup[g.file] }))
    .filter((g) => !!g.src)
    .map(async (g, i) => {
      const optimized = await getImage({
        src: g.src!,
        widths: [320, 480, 720, 1080],
        formats: ["avif", "webp", "jpg"],
      });
      const full = await getImage({
        src: g.src!,
        format: "webp",
        quality: 88,
      });
      const w = g.src!.width;
      const h = g.src!.height;
      return {
        ...g,
        thumbSrc: optimized.src,
        thumbSrcset: optimized.srcSet.attribute,
        fullSrc: full.src,
        width: w,
        height: h,
        span: computeSpan(w, h, i),
      } as const;
    })
);

const priceLabel = (p: number | null) =>
  p == null ? "Preis auf Anfrage" : `${p} €`;
---

<!--
  Pattern: 21st.dev / ravikatiyar / bento-gallery
    - Horizontale Drag-Bento-Galerie
    - Asymmetrische Tiles via col-span / row-span
    - Hover blendet Gradient-Overlay + Titel/Beschreibung ein
    - Click oeffnet Lightbox (statt Framer-Motion-Modal → PhotoSwipe)
-->
<section
  id="galerie"
  class="relative w-full overflow-hidden py-16 sm:py-24"
  aria-label="Galerie der Acryl-Werke"
>
  <div class="container mx-auto px-4 text-center reveal">
    <p class="font-display italic text-[var(--color-accent)] text-base sm:text-lg mb-3" style="letter-spacing:0.02em;">Die Künstlerin</p>
    <h2 class="font-display font-medium tracking-tight text-[clamp(32px,5vw,64px)] leading-[1.05]" style="letter-spacing:-0.015em;">
      Acryl. Großformatig. Aus dem Pfälzer Wald.
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-[15px] sm:text-lg text-[var(--color-ink-soft)]">
      Eine wachsende Sammlung großformatiger Werke. Ziehen, scrollen, klicken —
      jedes Werk öffnet sich in der Großansicht. Bei Interesse Kontakt über
      Facebook oder per Mail.
    </p>
  </div>

  <div
    class="bento-drag relative mt-10 sm:mt-12 w-full cursor-grab active:cursor-grabbing select-none"
    id="bento-drag"
    role="region"
    aria-label="Acryl-Werke (horizontal scrollbar)"
  >
    <div
      class="bento-grid grid auto-cols-[minmax(11rem,1fr)] sm:auto-cols-[minmax(13rem,1fr)] md:auto-cols-[minmax(15rem,1fr)] grid-flow-col grid-rows-2 gap-3 sm:gap-4 px-4 sm:px-6 md:px-8"
      id="bento-grid"
    >
      {items.map((item) => (
        <a
          href={item.fullSrc}
          data-pswp-width={item.width}
          data-pswp-height={item.height}
          data-title={item.title}
          data-dims={item.dims}
          data-price={priceLabel(item.price)}
          target="_blank"
          rel="noopener"
          aria-label={`${item.title} — ${item.dims} — Großansicht öffnen`}
          class={`bento-item ${item.span} group relative flex h-full min-h-[15rem] w-full min-w-[11rem] sm:min-w-[13rem] md:min-w-[15rem] cursor-pointer items-end overflow-hidden rounded-xl border border-[var(--color-line)] bg-[var(--color-paper-soft)] shadow-sm transition-shadow duration-300 ease-in-out hover:shadow-lg`}
        >
          <img
            src={item.thumbSrc}
            srcset={item.thumbSrcset}
            sizes="(min-width: 1024px) 360px, (min-width: 640px) 280px, 200px"
            alt={`${item.title} — ${item.dims}`}
            loading="lazy"
            decoding="async"
            width={item.width}
            height={item.height}
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            draggable={false}
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="bento-caption relative z-10 p-4 sm:p-5 translate-y-4 opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
            <h3 class="font-display text-lg sm:text-xl font-medium text-white" style="letter-spacing:-0.005em;">{item.title}</h3>
            <p class="mt-1 text-xs sm:text-sm italic text-white/85">{item.dims}</p>
            <p class="mt-2 text-[11px] sm:text-xs uppercase tracking-[0.18em] text-white/75 font-variant-numeric tabular-nums">
              {priceLabel(item.price)}
            </p>
          </div>
        </a>
      ))}
    </div>

    <p class="cg-hint mt-6 sm:mt-8 text-center text-[var(--color-muted)] text-[11px] sm:text-xs uppercase tracking-[0.22em]">
      Ziehen oder Wischen · Klick öffnet die Großansicht
    </p>
  </div>
</section>

<script>
  // Maus-Drag-zu-Scroll (Touch nutzt natives overflow-x Scroll der Plattform)
  const drag = document.getElementById("bento-drag");
  if (drag) {
    drag.addEventListener("pointerdown", (e) => {
      if (e.pointerType !== "mouse" || e.button !== 0) return;

      const startX = e.clientX;
      const startScroll = drag.scrollLeft;
      let movedDist = 0;
      let dragged = false;

      const onMove = (ev: PointerEvent) => {
        const dx = ev.clientX - startX;
        movedDist = Math.max(movedDist, Math.abs(dx));
        if (movedDist > 6) {
          if (!dragged) {
            dragged = true;
            drag.classList.add("dragged");
          }
          drag.scrollLeft = startScroll - dx;
        }
      };

      const onUp = () => {
        document.removeEventListener("pointermove", onMove);
        document.removeEventListener("pointerup", onUp);
        document.removeEventListener("pointercancel", onUp);
        drag.classList.remove("is-dragging");
        if (dragged) {
          // Klick nach echtem Drag verschlucken — sonst oeffnet die Lightbox
          const swallow = (ev: Event) => {
            ev.preventDefault();
            ev.stopPropagation();
          };
          window.addEventListener("click", swallow, { capture: true, once: true });
          requestAnimationFrame(() => drag.classList.remove("dragged"));
        }
      };

      document.addEventListener("pointermove", onMove);
      document.addEventListener("pointerup", onUp);
      document.addEventListener("pointercancel", onUp);
      drag.classList.add("is-dragging");
    });

    // Mausrad → horizontal scrollen
    drag.addEventListener(
      "wheel",
      (e) => {
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
          drag.scrollLeft += e.deltaY;
          e.preventDefault();
        }
      },
      { passive: false }
    );
  }

  // Staggered Reveal on-scroll fuer die Bento-Tiles
  const grid = document.getElementById("bento-grid");
  if (grid && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const tiles = Array.from(grid.querySelectorAll<HTMLElement>(".bento-item"));
    tiles.forEach((t) => t.classList.add("bento-pre"));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const idx = tiles.indexOf(entry.target as HTMLElement);
          if (idx === -1) return;
          setTimeout(() => entry.target.classList.add("bento-in"), Math.min(idx, 12) * 60);
          io.unobserve(entry.target);
        });
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.2 }
    );
    tiles.forEach((t) => io.observe(t));
  }

  // PhotoSwipe Lightbox (ersetzt das Framer-Modal aus der Demo)
  if (document.querySelector(".bento-item")) {
    import("photoswipe/lightbox").then(({ default: PhotoSwipeLightbox }) => {
      const lightbox = new PhotoSwipeLightbox({
        gallery: "#bento-grid",
        children: "a.bento-item",
        pswpModule: () => import("photoswipe"),
        bgOpacity: 0.95,
        showHideAnimationType: "fade",
      });
      lightbox.on("uiRegister", () => {
        lightbox.pswp?.ui?.registerElement({
          name: "custom-caption",
          order: 9,
          isButton: false,
          appendTo: "root",
          html: '<div class="pswp__custom-caption"></div>',
          onInit: (el) => {
            lightbox.pswp?.on("change", () => {
              const slide = lightbox.pswp?.currSlide?.data.element as HTMLAnchorElement | undefined;
              if (!slide) return;
              const t = slide.dataset.title ?? "";
              const d = slide.dataset.dims ?? "";
              const p = slide.dataset.price ?? "";
              el.innerHTML = `<strong>${t}</strong><br/>${d} · ${p}`;
            });
          },
        });
      });
      lightbox.init();
    });

    const captionCss = `
      .pswp__custom-caption {
        position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
        color: #f6f2ea; font-family: 'EB Garamond', Georgia, serif;
        font-size: 16px; letter-spacing: 0.02em;
        background: rgba(10,8,7,0.55); backdrop-filter: blur(8px);
        padding: 10px 18px; border-radius: 999px;
        max-width: min(90vw, 600px); text-align: center;
      }
      .pswp__custom-caption strong { font-size: 19px; font-weight: 600; }
    `;
    const style = document.createElement("style");
    style.textContent = captionCss;
    document.head.appendChild(style);
  }
</script>
