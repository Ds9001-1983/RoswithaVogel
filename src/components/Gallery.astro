---
import { getImage } from "astro:assets";
import galleryData from "../data/gallery.json";

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.jpg",
  { eager: true }
);
const lookup: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(galleryModules)) {
  lookup[path.split("/").pop()!] = mod.default;
}

const items = await Promise.all(
  galleryData
    .map((g) => ({ ...g, src: lookup[g.file] }))
    .filter((g) => !!g.src)
    .map(async (g) => {
      const optimized = await getImage({
        src: g.src!,
        widths: [320, 480, 720],
        formats: ["avif", "webp", "jpg"],
      });
      const full = await getImage({
        src: g.src!,
        format: "webp",
        quality: 88,
      });
      return {
        ...g,
        thumbSrc: optimized.src,
        thumbSrcset: optimized.srcSet.attribute,
        fullSrc: full.src,
        width: g.src!.width,
        height: g.src!.height,
      };
    })
);

const priceLabel = (p: number | null) =>
  p == null ? "Preis auf Anfrage" : `${p} €`;
---

<section id="galerie" class="px-6 py-20 sm:py-28 lg:py-40 overflow-hidden">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-12 sm:mb-16 reveal max-w-[760px] mx-auto px-2">
      <p class="font-display italic text-[var(--color-accent)] text-base sm:text-lg mb-2 sm:mb-3" style="letter-spacing:0.02em;">Die Künstlerin</p>
      <h2 class="font-display font-medium text-[clamp(34px,5.2vw,72px)] leading-[1.05]" style="letter-spacing:-0.015em;">
        Acryl. Großformatig.<br class="sm:hidden"/> Aus dem Pfälzer Wald.
      </h2>
      <p class="mt-4 sm:mt-5 text-[var(--color-ink-soft)] max-w-[58ch] mx-auto leading-relaxed text-[15px] sm:text-base">
        Eine wachsende Sammlung großformatiger Acryl-Werke. Beim Scrollen wandert
        die Ausstellung. Klick auf ein Werk öffnet die Großansicht — bei Interesse
        Kontakt über Facebook oder per Mail.
      </p>
    </div>

    <div
      class="cg-stage reveal"
      id="circular-gallery"
      role="region"
      aria-label="Acryl-Werke, dreidimensional rotierend"
    >
      <div class="cg-rotor" id="cg-rotor">
        {items.map((item) => (
          <a
            class="cg-card"
            href={item.fullSrc}
            data-pswp-width={item.width}
            data-pswp-height={item.height}
            data-title={item.title}
            data-dims={item.dims}
            data-price={priceLabel(item.price)}
            target="_blank"
            rel="noopener"
            aria-label={`${item.title} — ${item.dims} — Großansicht öffnen`}
          >
            <img
              src={item.thumbSrc}
              srcset={item.thumbSrcset}
              sizes="(min-width: 1024px) 320px, (min-width: 640px) 260px, 200px"
              alt={`${item.title} — ${item.dims}`}
              loading="lazy"
              decoding="async"
              width={item.width}
              height={item.height}
            />
            <div class="cg-caption">
              <strong>{item.title}</strong>
              <em class="dims">{item.dims}</em>
              <p class="price">{priceLabel(item.price)}</p>
            </div>
          </a>
        ))}
      </div>

      <p class="cg-hint" aria-hidden="true">scrollen oder warten · die Galerie dreht sich</p>
    </div>
  </div>
</section>

<script>
  const stage = document.getElementById("circular-gallery");
  const rotor = document.getElementById("cg-rotor");
  if (stage && rotor) {
    const cards = Array.from(stage.querySelectorAll<HTMLElement>(".cg-card"));
    const N = cards.length;
    const anglePerItem = 360 / N;
    const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

    const getRadius = () =>
      parseFloat(
        getComputedStyle(stage).getPropertyValue("--cg-radius").trim() || "540"
      );

    const placeCards = () => {
      const r = getRadius();
      cards.forEach((c, i) => {
        c.style.transform = `rotateY(${i * anglePerItem}deg) translateZ(${r}px)`;
      });
    };
    placeCards();
    window.addEventListener("resize", placeCards);

    let rotation = 0;
    let isScrolling = false;
    let scrollTimer: ReturnType<typeof setTimeout> | null = null;
    const autoSpeed = 0.045;

    const applyRotation = () => {
      rotor.style.transform = `rotateY(${rotation}deg)`;
      cards.forEach((c, i) => {
        const itemAngle = i * anglePerItem;
        const rel = ((itemAngle + rotation) % 360 + 360) % 360;
        const norm = Math.abs(rel > 180 ? 360 - rel : rel);
        const opacity = Math.max(0.25, 1 - norm / 180);
        c.style.opacity = String(opacity);
        // Cards weit hinten kein Klick mehr abnehmen
        c.style.pointerEvents = opacity < 0.45 ? "none" : "auto";
      });
    };

    const onScroll = () => {
      isScrolling = true;
      if (scrollTimer) clearTimeout(scrollTimer);
      const scrollable =
        document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
      rotation = progress * 360;
      applyRotation();
      scrollTimer = setTimeout(() => {
        isScrolling = false;
      }, 160);
    };
    window.addEventListener("scroll", onScroll, { passive: true });

    let frame = 0;
    const tick = () => {
      if (!isScrolling && !reducedMotion) {
        rotation += autoSpeed;
        applyRotation();
      }
      frame = requestAnimationFrame(tick);
    };
    frame = requestAnimationFrame(tick);

    // initial state
    onScroll();
  }

  // PhotoSwipe-Lightbox
  if (document.querySelector(".cg-card")) {
    import("photoswipe/lightbox").then(({ default: PhotoSwipeLightbox }) => {
      const lightbox = new PhotoSwipeLightbox({
        gallery: "#circular-gallery",
        children: "a.cg-card",
        pswpModule: () => import("photoswipe"),
        bgOpacity: 0.95,
        showHideAnimationType: "fade",
      });
      lightbox.on("uiRegister", () => {
        lightbox.pswp?.ui?.registerElement({
          name: "custom-caption",
          order: 9,
          isButton: false,
          appendTo: "root",
          html: '<div class="pswp__custom-caption"></div>',
          onInit: (el) => {
            lightbox.pswp?.on("change", () => {
              const slide = lightbox.pswp?.currSlide?.data.element as HTMLAnchorElement | undefined;
              if (!slide) return;
              const t = slide.dataset.title ?? "";
              const d = slide.dataset.dims ?? "";
              const p = slide.dataset.price ?? "";
              el.innerHTML = `<strong>${t}</strong><br/>${d} · ${p}`;
            });
          },
        });
      });
      lightbox.init();
    });

    const captionCss = `
      .pswp__custom-caption {
        position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
        color: #f6f2ea; font-family: 'EB Garamond', Georgia, serif;
        font-size: 16px; letter-spacing: 0.02em;
        background: rgba(10,8,7,0.55); backdrop-filter: blur(8px);
        padding: 10px 18px; border-radius: 999px;
        max-width: min(90vw, 600px); text-align: center;
      }
      .pswp__custom-caption strong { font-size: 19px; font-weight: 600; }
    `;
    const style = document.createElement("style");
    style.textContent = captionCss;
    document.head.appendChild(style);
  }
</script>
